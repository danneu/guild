# Guild environment configuration.
# Copy to .env and fill in the blanks: `cp .env.example .env`
# All vars are read in server/config.ts. The app boots with the defaults below;
# unset secrets simply disable the feature they belong to (Discord, email,
# CAPTCHA, etc.) -- config.ts logs which subsystems are configured at startup.

# --- Core ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
# postgres://<user>:<pass>@<host>:<port>/<dbname>
DATABASE_URL=postgres://localhost:5432/guild
# Base URL used in email links; defaults to http://localhost:$PORT
HOST=http://localhost:3000
# 512-bit (64-byte) hex secret for email verification / token signing. REQUIRED.
SECRET=

# --- AWS: S3 (uploads) + SES (email) ------------------------------------
# Email is considered configured when HOST + AWS_KEY + AWS_SECRET are set.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Legacy duplicates still read by config.ts; set to the same values as above.
AWS_KEY=
AWS_SECRET=
# S3 buckets for avatar/image processing (unset = those features warn + disable)
S3_AVATAR_BUCKET=avatars.example.com
S3_IMAGE_BUCKET=img.example.com

# --- Discord (OAuth login + bot) ----------------------------------------
# All four must be set for Discord to be enabled.
DISCORD_APP_CLIENTID=
DISCORD_APP_CLIENTSECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# --- Anti-spam / CAPTCHA ------------------------------------------------
AKISMET_KEY=
RECAPTCHA_SITEKEY=
RECAPTCHA_SITESECRET=
# Cloudflare Turnstile (both required to enable)
CF_TURNSTILE_SITEKEY=
CF_TURNSTILE_SECRET=

# --- Monitoring / logging -----------------------------------------------
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=localhost-guild
PAPERTRAIL_API_TOKEN=

# --- Feature toggles & external services --------------------------------
# "true" to bring the private-message system online
IS_PM_SYSTEM_ONLINE=false
# any non-empty value enables ads
ENABLE_ADS=
CHAT_SERVER_URL=http://localhost:3001
# comma-separated user slugs to hide from reverse-lookup
CLOAKED_SLUGS=

# --- Site content IDs (point at real post/topic/user IDs in your DB) -----
STAFF_REPRESENTATIVE_ID=
WELCOME_POST_ID=
FAQ_POST_ID=
RULES_POST_ID=
CURRENT_FEEDBACK_TOPIC_ID=
LATEST_RPGN_TOPIC_ID=
LATEST_RPGN_IMAGE_URL=

# --- Forum limits (all optional; defaults shown) ------------------------
# MIN_TOPIC_TITLE_LENGTH=3
# MAX_TOPIC_TITLE_LENGTH=150
# MIN_POST_LENGTH=1
# MAX_POST_LENGTH=150000
# MIN_UNAME_LENGTH=2
# MAX_UNAME_LENGTH=15
# MAX_BIO_LENGTH=100000
# MAX_VM_LENGTH=300
# MAX_CONVO_PARTICIPANTS=10
# MAX_CO_GM_COUNT=2
# POSTS_PER_PAGE=20
# USERS_PER_PAGE=20
# RECENT_POSTS_PER_PAGE=5
# CONVOS_PER_PAGE=10
# SEARCH_RESULTS_PER_PAGE=50
# MENTIONS_PER_POST=10
# QUOTES_PER_POST=10
